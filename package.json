{
  "name": "loomwright-v2",
  "version": "0.1.0",
  "private": true,
  "description": "Extracted Loomwright v2 static design build.",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "start": "npm run dev",
    "validate": "node scripts/validate-static-site.js && node scripts/audit-callbacks.js",
    "audit-callbacks": "node scripts/export-callback-names.js && node scripts/generate-callback-names-data.js && node scripts/audit-callbacks.js",
    "build": "node scripts/build-static.js",
    "preview": "vite preview --host 0.0.0.0",
    "test:smoke": "node scripts/smoke-services.js",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "vite": "^8.0.13"
  }
}
